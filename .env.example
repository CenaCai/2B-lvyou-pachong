# Google Sheet target from the user-provided URL.
GOOGLE_SHEET_ID=1eUknA5fqniT1KMLdsmqKSrpVXSZW726e3MXvfieOUU8
GOOGLE_WORKSHEET_NAME=leads

# Use ONE of these auth methods.
# Option A: path to a service-account JSON file mounted in Crawlab.
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/google-service-account.json

# Option B: raw service-account JSON string stored as Crawlab secret/env.
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Comma-separated URLs that you are authorized to crawl.
# Do not use this template to bypass login, anti-bot systems, or collect private personal data.
SOURCE_URLS=https://example.com/contact

# Optional generic CSS selectors for pages you control or have permission to crawl.
NAME_SELECTOR=
COMPANY_SELECTOR=
NEXT_PAGE_SELECTOR=

# Crawling controls.
HEADLESS=true
MAX_PAGES=20
REQUEST_DELAY_SECONDS=2
DEFAULT_COUNTRY=
DEFAULT_SOURCE=authorized_web

# If true, write only a local CSV preview instead of Google Sheets.
DRY_RUN=false
